# App public URL (used in email links)
APP_URL=http://localhost:5000

# Email — SMTP (works with Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
# Your Gmail address
SMTP_USER=nikolastankovic411@gmail.com
# Gmail App Password (not your regular password)
# Generate at: https://myaccount.google.com/apppasswords
SMTP_PASSWORD=wevzwnjgppwmgtdu
# Optional: display address in From header
EMAIL_FROM=Kucni Poslovi

